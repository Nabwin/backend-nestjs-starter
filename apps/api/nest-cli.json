{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "typecheck": false,
      "options": {
        "swcrcPath": ".swcrc",
        "extensions": [".js", ".ts", ".tsx"]
      }
    },
    "deleteOutDir": true
  }
}