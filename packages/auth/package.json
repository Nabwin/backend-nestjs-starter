{
  "name": "@repo/auth",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./decorators": {
      "types": "./src/decorators/index.ts",
      "default": "./dist/decorators/index.js"
    },
    "./guards": {
      "types": "./src/guards/index.ts",
      "default": "./dist/guards/index.js"
    },
    "./strategies": {
      "types": "./src/strategies/index.ts",
      "default": "./dist/strategies/index.js"
    },
    "./strategies/types": {
      "types": "./src/strategies/types.ts",
      "default": "./dist/strategies/types.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint",
    "format": "oxfmt",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/swagger": "^11.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1"
  }
}
