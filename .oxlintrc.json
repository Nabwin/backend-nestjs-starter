{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "unicorn"],
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    ".turbo/**",
    "apps/api/src/db/generated/**"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-extraneous-class": ["warn", { "allowWithDecorator": true }]
  }
}